ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false

# main.py expects this exact variable name — keep it, even though it holds an OpenAI key
GEMINI_API_KEY=API
OPENAI_API_KEY=API
LLM_API_KEY=API

LLM_PROVIDER=mistral
LLM_MODEL=mistral/mistral-large-latest

EMBEDDING_PROVIDER=mistral
EMBEDDING_MODEL=mistral-embed


EMBEDDING_ENDPOINT=https://api.mistral.ai/v1


