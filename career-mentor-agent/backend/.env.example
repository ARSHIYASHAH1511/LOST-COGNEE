# ─────────────────────────────────────────────
# AI Career Mentor Chatbot — Environment Variables
# Copy this file to .env and fill in real values.
# ─────────────────────────────────────────────

# Your Google Gemini API key (get it from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Cognee uses this key for its internal LLM calls (graph building).
# You can reuse the same Gemini key here.
LLM_API_KEY=your_gemini_api_key_here

# LLM provider name — "gemini" maps to LiteLLM's Gemini integration inside Cognee.
LLM_PROVIDER=gemini

# Exact model string passed to LiteLLM
LLM_MODEL=gemini/gemini-2.0-flash

# Embedding provider — Gemini offers a free embedding model
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=models/embedding-001

# Leave blank unless you need a custom endpoint
EMBEDDING_ENDPOINT=
